# macOS
.DS_Store

# Editor
*~
*.swp
*.swo
.vscode/
.idea/

# Quartus build artifacts (regenerated by `quartus_sh --flow compile`)
db/
incremental_db/
output_files/
simulation/
*.qws
*.smsg
*.bak
*.rpt
*.summary
*.pin
*.done
*.jdi

# Qsys / Platform Designer generated
soc_system/synthesis/
soc_system/testbench/
soc_system/synth/
**/.qsys_edit/
**/.qsys-pro/

# C build outputs
*.o
*.d
sw/hello
sw/vga_ball

# SD card images (large, do not commit)
*.img
*.sdimg

# Scratch
/tmp/
/scratch/

# ModelSim simulation build artifacts (regenerated by `make -C sim`)
sim/work/
sim/transcript
sim/*.wlf
sim/*_dut.txt

# Python-generated golden vectors (regenerated by `make -C sim vectors`)
sim/vectors/*.txt

# Python bytecode caches
__pycache__/
*.pyc
